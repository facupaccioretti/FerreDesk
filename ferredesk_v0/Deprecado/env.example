# Configuracion de la base de datos
POSTGRES_DB=ferredesk
POSTGRES_USER=ferredesk_user
POSTGRES_PASSWORD=ferredesk_pass_2024
DATABASE_URL=postgresql://ferredesk_user:ferredesk_pass_2024@postgres:5432/ferredesk

# Configuracion de Django
DEBUG=False
SECRET_KEY=django-insecure-ferredesk-2024-production-key
ENVIRONMENT=production
PRIMARY_DOMAIN=ferredesk.xyz
PUBLIC_BASE_URL=https://ferredesk.xyz
FRONTEND_URL=https://ferredesk.xyz
SESSION_COOKIE_DOMAIN=.ferredesk.xyz
ALLOWED_HOSTS=ferredesk.xyz,.ferredesk.xyz,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://ferredesk.xyz,https://*.ferredesk.xyz

# Email transaccional Resend API para produccion
DEFAULT_FROM_EMAIL=no-reply@ferredesk.xyz
RESEND_API_KEY=re_example
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT=10
